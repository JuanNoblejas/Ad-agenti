<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".ui.home.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_large">

        <!-- App Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_large"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/primary"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold" />

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/padding_large">

            <ImageView
                android:id="@+id/ivStatusIcon"
                android:layout_width="@dimen/icon_size_large"
                android:layout_height="@dimen/icon_size_large"
                android:contentDescription="@string/status_unknown"
                android:src="@drawable/ic_home"
                android:layout_marginBottom="@dimen/margin_small" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/status_unknown"
                android:textColor="@color/textPrimary"
                android:textSize="@dimen/text_size_xlarge"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLastEvent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:gravity="center"
                android:text="@string/no_events"
                android:textColor="@color/textSecondary"
                android:textSize="@dimen/text_size_normal" />

        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/margin_large" />

        <!-- Tracking Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/padding_normal">

            <View
                android:id="@+id/viewTrackingDot"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@color/error" />

            <TextView
                android:id="@+id/tvTrackingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/tracking_inactive"
                android:textColor="@color/textPrimary"
                android:textSize="@dimen/text_size_normal"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Home Location Info -->
        <TextView
            android:id="@+id/tvHomeLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:padding="@dimen/padding_normal"
            android:text="@string/home_not_set"
            android:textColor="@color/textSecondary"
            android:textSize="@dimen/text_size_normal" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/margin_normal" />

        <!-- Set Home Button -->
        <Button
            android:id="@+id/btnSetHome"
            style="@style/Theme.Wanda.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/margin_normal"
            android:text="@string/btn_set_home"
            android:textSize="@dimen/text_size_normal" />

        <!-- Edit Home Button -->
        <Button
            android:id="@+id/btnEditHome"
            style="@style/Theme.Wanda.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/margin_normal"
            android:text="@string/btn_edit_home"
            android:textSize="@dimen/text_size_normal" />

        <!-- Delete Home Button -->
        <Button
            android:id="@+id/btnDeleteHome"
            style="@style/Theme.Wanda.Button.Danger"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/margin_normal"
            android:text="Delete home location"
            android:textSize="@dimen/text_size_normal"
            android:visibility="gone" />

        <!-- Toggle Tracking Button -->
        <Button
            android:id="@+id/btnToggleTracking"
            style="@style/Theme.Wanda.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/margin_normal"
            android:text="@string/btn_start_tracking"
            android:textSize="@dimen/text_size_normal" />

    </LinearLayout>

</ScrollView>
